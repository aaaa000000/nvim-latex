# -- SNIPPETS --


# new glossary entry
snippet gloss "Glossary Entry"  b
	\newglossaryentry{${1:entry}}{
			name = {${2:name}},
			symbol = {\ensuremath{${3:symbol}}},
			description = {${4:description}}
	}
#


# beamer frame enviornment
snippet frame "Beamer Frame" b
	\begin{frame}

		\textbf{${1:label}} ${2:claim}
		\vspace{.2in}
		\pause


	\end{frame}

	%%% -------------------------------------------------------
#




# beamer item enviornment
snippet bemit "Beamer Item" b
	\textbf{${1:label}} ${2:claim}
	\vspace{.2in}
	\pause
#


# Ttheorem enviornment
snippet Tthm "Ttheorem" b
	\vspace{.05in}
	\begin{Tthm} \label{${1:label}}
		${2:claim}
	\end{Tthm}

	\begin{proof}
		${0}
    \qed
	\end{proof}
#


# Mtheorem enviornment
snippet Mthm "Mtheorem" b
	\vspace{.05in}
	\begin{Mthm} \label{${1:label}}
		${2:claim}
	\end{Mthm}

	\begin{proof}
		${0}
    \qed
	\end{proof}
#


